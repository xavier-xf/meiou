	cd /home/leo/linphone_sdk && $(MAKE) -f share/freetype/CMakeFiles/freetype.dir/build.make share/freetype/CMakeFiles/freetype.dir/smooth/smooth.c.o
.PHONY : smooth/smooth.c.o


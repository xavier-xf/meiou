            irq-gpio = <&gpio 42 1>;
            reset-gpio = <&gpio 41 1>;
            TP_MAX_X = <1024>;
            TP_MAX_Y = <600>;
            interrupt-parent=<&gpio>;
            interrupts=<42 1>;
